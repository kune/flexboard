# Dex OIDC configuration template.
#
# For local development or VM deployment without running init.sh:
#   cp config/dex.yaml.example config/dex.yaml
#
# ${FLEXBOARD_BASE_URL} is expanded by Dex at startup from the environment
# variable set in docker-compose.yml / docker-compose.prod.yml.
#
# All test accounts below use the password: Test1234!

issuer: ${FLEXBOARD_BASE_URL}/dex

storage:
  type: memory

web:
  http: 0.0.0.0:5556

oauth2:
  skipApprovalScreen: true

staticClients:
  - id: flexboard-web
    name: Flexboard Web
    redirectURIs:
      - ${FLEXBOARD_BASE_URL}/auth/callback
    public: true

enablePasswordDB: true

staticPasswords:
  - email: admin@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: admin
    userID: "admin-000001"

  - email: alice@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: alice
    userID: "user-000002"

  - email: bob@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: bob
    userID: "user-000003"

  - email: carol@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: carol
    userID: "user-000004"

  - email: dave@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: dave
    userID: "user-000005"

  - email: eve@flexboard.localhost
    hash: "$2a$10$O3Vqj3kfz9OWR3pZNAXboe3XetsMxGHnzeWczwDrEVFgPq0LbSxfi"
    username: eve
