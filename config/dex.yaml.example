# Dex OIDC configuration template.
#
# scripts/init.sh generates config/dex.yaml automatically.
#
# For manual generation (e.g. prod deployments without running init.sh):
#   export FLEXBOARD_BASE_URL=http://192.168.1.100
#   export LLDAP_ADMIN_PASS=YourAdminPassword
#   sed "s|\${FLEXBOARD_BASE_URL}|$FLEXBOARD_BASE_URL|g; s|\${LLDAP_ADMIN_PASS}|$LLDAP_ADMIN_PASS|g" \
#     config/dex.yaml.example > config/dex.yaml
#
# ${FLEXBOARD_BASE_URL} and ${LLDAP_ADMIN_PASS} are expanded by the sed
# command above. Dex does not expand shell variables from its config file.

issuer: ${FLEXBOARD_BASE_URL}/dex

storage:
  type: memory

web:
  http: 0.0.0.0:5556

oauth2:
  skipApprovalScreen: true

staticClients:
  - id: flexboard-web
    name: Flexboard Web
    redirectURIs:
      - ${FLEXBOARD_BASE_URL}/auth/callback
      # Add additional URLs if the app is accessible from more than one origin:
      # - https://flexboard.example.com/auth/callback
    public: true

# LDAP connector — authenticates users from the LLDAP container.
# LLDAP listens on port 3890 (LDAP) and 17170 (web UI / API).
# Manage users and reset passwords at http://<host>:17170
connectors:
  - type: ldap
    id: ldap
    name: LLDAP
    config:
      host: lldap:3890
      insecureNoSSL: true
      # Bind with the LLDAP admin account.
      # bindPW must match LLDAP_ADMIN_PASS in docker-compose.yml / .env
      bindDN: uid=admin,ou=people,dc=flexboard,dc=localhost
      bindPW: "${LLDAP_ADMIN_PASS}"
      usernamePrompt: Email Address
      userSearch:
        baseDN: ou=people,dc=flexboard,dc=localhost
        filter: "(objectClass=person)"
        username: mail
        idAttr: uid
        emailAttr: mail
        nameAttr: cn
      groupSearch:
        baseDN: ou=groups,dc=flexboard,dc=localhost
        filter: "(objectClass=groupOfUniqueNames)"
        userMatchers:
          - userAttr: DN
            groupAttr: uniqueMember
        nameAttr: cn
