# ── Zitadel secrets ──────────────────────────────────────────────────────────
# 32-character random string: openssl rand -base64 32 | tr -d '/+=' | head -c 32
ZITADEL_MASTERKEY=<32-char-random-key>

# Initial admin account (admin@flexboard.localhost is the default username)
ZITADEL_ADMIN_PASSWORD=<strong-password-min-8-chars-upper-lower-digit-symbol>

# Password for the internal Zitadel PostgreSQL database
ZITADEL_DB_PASSWORD=<strong-password>

# ── OIDC (frontend) ───────────────────────────────────────────────────────────
# Public URL of Zitadel — always http://localhost for local development
VITE_ZITADEL_DOMAIN=http://localhost

# ── Set automatically by scripts/init.sh (or scripts/setup-zitadel.sh) ───────
ZITADEL_PROJECT_ID=
VITE_ZITADEL_CLIENT_ID=
