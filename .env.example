# ── Backend ──────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/flexboard
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Zitadel OIDC (backend token validation)
ZITADEL_DOMAIN=http://zitadel:8080
ZITADEL_PROJECT_ID=<your-project-id>

# ── Frontend (injected at build time via Vite) ────────────
VITE_API_BASE_URL=/api/v1
VITE_ZITADEL_DOMAIN=http://localhost:8080
VITE_ZITADEL_CLIENT_ID=<your-client-id>

# ── Zitadel ──────────────────────────────────────────────
ZITADEL_MASTERKEY=<32-char-random-key>
# Initial admin user (created on first start)
ZITADEL_ADMIN_USERNAME=admin@flexboard.localhost
ZITADEL_ADMIN_PASSWORD=<strong-password-min-8-chars-upper-lower-digit>

# ── Zitadel DB (PostgreSQL) ───────────────────────────────
ZITADEL_DB_PASSWORD=<strong-password>
