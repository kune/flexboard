{
  "name": "@flexboard/backend",
  "private": true,
  "version": "0.5.2",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists .env.local src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@flexboard/shared": "workspace:*",
    "fastify": "^5.2.1",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.0",
    "mongoose": "^8.9.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
